# ============================================================================
# Joy Meeting Client Configuration (Ubuntu Headless)
# Copy this to .env and fill in your values
# ============================================================================

# WebSocket URL of the onebudd-realtime server
PIPELINE_WS_URL=wss://api.onebudd.com/ws

# API key for onebudd-realtime (from your dashboard)
API_KEY=sk_live_93172cabdc034e439b544fc629d1effc76699441a3444c6daac2e15d668d51c6

# The Google Meet link to automatically join
MEET_URL="https://meet.google.com/ywv-enra-mgb"

# Audio device names (PulseAudio virtual devices)
# Input: The pulse monitor capturing audio from the meeting (e.g. Chrome's speaker)
# Output: The null sink that we inject TTS audio into (e.g. Chrome's mic source master)
INPUT_DEVICE="VirtualSpeaker.monitor"
OUTPUT_DEVICE="VirtualSpeaker"

# Audio format (must match what onebudd-realtime expects)
SAMPLE_RATE=16000
CHANNELS=1
ENCODING=signed-integer
BITS_PER_SAMPLE=16

# Custom wake word (optional, default: "hey joy")
WAKE_WORD=hey joy

# Client-side interruption controls
CANCEL_PHRASES=never mind,cancel,stop,ignore that
INTERRUPT_ON_SPEECH=true
INTERRUPT_ON_CANCEL=true
VAD_THRESHOLD=0.02
INTERRUPT_COOLDOWN_MS=1200
MIN_QUERY_CHARS=3
MIN_QUERY_WORDS=4
ACTIVATION_TIMEOUT_MS=1500

# Language for the session
LANGUAGE=en-US
